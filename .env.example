# ─────────────────────────────────────────────────────────────────────────────
# 사용할 증권사
#   값: kiwoom | kis | ls | meritz | daishin
#   meritz / daishin 은 스캐폴드 단계 — 호출 시 NotImplementedError 발생.
BROKER=kiwoom

# 환경: mock (모의투자) | prod (운영)
#   broker 별 호스트가 자동 결정됨
BROKER_ENV=mock

# ─────────────────────────────────────────────────────────────────────────────
# 키움증권 (https://openapi.kiwoom.com)
KIWOOM_APP_KEY=
KIWOOM_SECRET_KEY=
KIWOOM_ACCOUNT_NO=

# ─────────────────────────────────────────────────────────────────────────────
# 한국투자증권 / 한투 (KIS, https://apiportal.koreainvestment.com)
#   계좌번호: 'CANO-PRDT' 형식 권장 (예: 12345678-01).
#   하이픈 없이 10자리 또는 8자리 + 기본 PRDT '01' 도 허용.
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=

# ─────────────────────────────────────────────────────────────────────────────
# LS증권 (구 이베스트, https://openapi.ls-sec.co.kr)
LS_APP_KEY=
LS_APP_SECRET=
LS_ACCOUNT_NO=
# 일부 TR (잔고 t0424, 예수금 CSPAQ12200 등)은 계좌 비밀번호 4자리가 필요함
LS_ACCOUNT_PWD=

# ─────────────────────────────────────────────────────────────────────────────
# 메리츠증권 (스캐폴드 — 실제 API 연동은 brokers/meritz.py 의 TODO 참고)
MERITZ_APP_KEY=
MERITZ_APP_SECRET=
MERITZ_ACCOUNT_NO=
MERITZ_ACCOUNT_PWD=

# ─────────────────────────────────────────────────────────────────────────────
# 대신증권 (CYBOS Plus, Windows 32-bit Python 전용)
#   - HTS 로그인이 인증을 대신함 → APP KEY/SECRET 불필요
#   - 사전: pywin32 설치 + CYBOS Plus 설치 + HTS 로그인된 상태
DAISHIN_APP_KEY=
DAISHIN_APP_SECRET=
DAISHIN_ACCOUNT_NO=
DAISHIN_ACCOUNT_PWD=

# ─────────────────────────────────────────────────────────────────────────────
# AI 코멘트 제공자: gemini | ollama | none
# 비워두면 GEMINI_API_KEY 가 있을 때 gemini, 없으면 none
AI_PROVIDER=

# Gemini (https://aistudio.google.com 에서 무료 발급)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Ollama (로컬 LLM, https://ollama.com)
# 사전에 `ollama pull llama3.1` 등으로 모델을 받아두세요.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# 매매일지 출력 디렉토리
JOURNAL_DIR=./journals

# 수동 원장(manual) 국내 시세 조회 API: yahoo | kiwoom | kis  (해외주식은 항상 yahoo)
# kiwoom/kis 선택 시 해당 증권사 APP KEY/SECRET 필요
MANUAL_DOMESTIC_API=yahoo
